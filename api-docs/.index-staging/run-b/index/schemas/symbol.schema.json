{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.quant-docs/schemas/symbol.schema.json",
  "type": "object",
  "required": ["id", "platform", "variant", "source_role", "resolution_priority", "record_type", "canonical_name", "qualified_name", "display_name", "aliases", "category_path", "summary", "signature", "signatures", "parameters", "returns", "exceptions", "environments", "asset_types", "frequency_support", "availability_notes", "deprecation_status", "version_notes", "related_symbols", "example_refs", "document_id", "markdown_file", "source_file", "source_url", "source_anchor", "evidence_type", "evidence_heading", "evidence_excerpt", "confidence", "review_required", "extraction_warnings", "content_sha256"],
  "properties": {
    "id": { "type": "string", "pattern": "^sym:" },
    "document_id": { "type": "string", "pattern": "^doc:" },
    "platform": { "enum": ["ptrade", "qmt", "joinquant"] },
    "variant": { "type": "string" },
    "source_role": { "enum": ["primary", "supplementary"] },
    "resolution_priority": { "type": "integer" },
    "record_type": { "enum": ["api_function", "callback", "method", "object", "field", "class", "constant", "module", "data_table", "query_namespace", "indicator", "factor", "event", "enum", "api_group"] },
    "canonical_name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
    "qualified_name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$" },
    "display_name": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "summary": { "type": ["string", "null"] },
    "category_path": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "signature": { "type": ["string", "null"] },
    "signatures": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "parameters": { "type": "array", "items": { "$ref": "#/$defs/parameter" } },
    "returns": { "type": "array", "items": { "$ref": "#/$defs/return" } },
    "exceptions": { "type": "array", "items": { "type": "object" } },
    "environments": { "type": "array", "items": { "enum": ["research", "backtest", "simulation", "live_trade", "strategy", "unknown"] }, "uniqueItems": true },
    "asset_types": { "type": "array", "items": { "type": "string" } },
    "frequency_support": { "type": "array", "items": { "type": "string" } },
    "availability_notes": { "type": ["string", "null"] },
    "deprecation_status": { "type": ["string", "null"] },
    "version_notes": { "type": "array", "items": { "type": "string" } },
    "related_symbols": { "type": "array", "items": { "type": "string" } },
    "example_refs": { "type": "array", "items": { "type": "string" } },
    "source_anchor": { "type": ["string", "null"] },
    "source_file": { "type": "string", "pattern": "^api-docs/raw/" },
    "source_url": { "type": ["string", "null"] },
    "markdown_file": { "type": "string", "pattern": "^api-docs/normalized/" },
    "evidence_type": { "type": "string", "minLength": 1 },
    "evidence_heading": { "type": "string", "minLength": 1 },
    "evidence_excerpt": { "type": "string", "minLength": 1, "maxLength": 500 },
    "evidence": { "type": "object", "required": ["heading", "line_start", "line_end", "signature_source"], "properties": { "heading": { "type": "string" }, "line_start": { "type": "integer", "minimum": 1 }, "line_end": { "type": "integer", "minimum": 1 }, "signature_source": { "enum": ["formal_code_block", "formal_heading", "none"] } }, "additionalProperties": false },
    "confidence": { "enum": ["high", "medium", "low"] },
    "review_required": { "type": "boolean" },
    "extraction_warnings": { "type": "array", "items": { "type": "string" } },
    "content_sha256": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "parameter": { "type": "object", "required": ["name", "type", "required", "default", "description"], "properties": { "name": { "type": "string" }, "type": { "type": ["string", "null"] }, "required": { "type": ["boolean", "null"] }, "default": { "type": ["string", "null"] }, "description": { "type": ["string", "null"] } }, "additionalProperties": false },
    "return": { "type": "object", "required": ["type", "description", "fields"], "properties": { "type": { "type": ["string", "null"] }, "description": { "type": ["string", "null"] }, "fields": { "type": "array", "items": { "type": "object" } } }, "additionalProperties": false }
  },
  "additionalProperties": false
}
