{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.quant-docs/schemas/document.schema.json",
  "type": "object",
  "required": ["id", "platform", "variant", "source_role", "resolution_priority", "document_type", "title", "section_path", "markdown_file", "markdown_sha256", "source_file", "source_url", "source_anchor", "source_sha256", "captured_at", "canonical", "alias_of", "character_count", "heading_count", "code_block_count", "markdown_table_count", "html_table_count", "conversion_warnings", "index_status", "index_warnings"],
  "properties": {
    "id": { "type": "string", "pattern": "^doc:" },
    "platform": { "enum": ["ptrade", "qmt", "joinquant"] },
    "variant": { "type": "string", "minLength": 1 },
    "source_role": { "enum": ["primary", "supplementary"] },
    "resolution_priority": { "type": "integer", "minimum": 0 },
    "document_type": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "section_path": { "type": "array", "items": { "type": "string" } },
    "markdown_file": { "type": "string", "pattern": "^api-docs/normalized/.+\\.md$" },
    "markdown_sha256": { "$ref": "#/$defs/hash" },
    "source_file": { "type": "string", "pattern": "^api-docs/raw/" },
    "source_url": { "type": ["string", "null"] },
    "source_anchor": { "type": ["string", "null"] },
    "source_sha256": { "$ref": "#/$defs/hash" },
    "captured_at": { "type": ["string", "null"] },
    "canonical": { "const": true },
    "alias_of": { "type": "null" },
    "character_count": { "type": "integer", "minimum": 1 },
    "heading_count": { "type": "integer", "minimum": 0 },
    "code_block_count": { "type": "integer", "minimum": 0 },
    "markdown_table_count": { "type": "integer", "minimum": 0 },
    "html_table_count": { "type": "integer", "minimum": 0 },
    "conversion_warnings": { "type": "array", "items": { "type": "string" } },
    "index_status": { "const": "indexed" },
    "index_warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": { "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
  "additionalProperties": false
}
