{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.quant-docs/schemas/chunk.schema.json",
  "type": "object",
  "required": ["id", "document_id", "platform", "variant", "source_role", "resolution_priority", "document_type", "title", "heading_path", "symbol_ids", "content", "content_sha256", "markdown_file", "source_url", "source_anchor", "line_start", "line_end", "chunk_index", "previous_chunk_id", "next_chunk_id", "character_count", "token_estimate", "contains_code", "contains_table", "contains_warning", "index_warnings"],
  "properties": {
    "id": { "type": "string", "pattern": "^chk:" },
    "document_id": { "type": "string", "pattern": "^doc:" },
    "platform": { "enum": ["ptrade", "qmt", "joinquant"] },
    "variant": { "type": "string" },
    "source_role": { "enum": ["primary", "supplementary"] },
    "resolution_priority": { "type": "integer" },
    "document_type": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "heading_path": { "type": "array", "items": { "type": "string" } },
    "symbol_ids": { "type": "array", "items": { "type": "string", "pattern": "^sym:" }, "uniqueItems": true },
    "content": { "type": "string", "minLength": 1 },
    "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "markdown_file": { "type": "string", "pattern": "^api-docs/normalized/" },
    "source_url": { "type": ["string", "null"] },
    "source_anchor": { "type": ["string", "null"] },
    "line_start": { "type": "integer", "minimum": 1 },
    "line_end": { "type": "integer", "minimum": 1 },
    "chunk_index": { "type": "integer", "minimum": 0 },
    "previous_chunk_id": { "type": ["string", "null"] },
    "next_chunk_id": { "type": ["string", "null"] },
    "character_count": { "type": "integer", "minimum": 1 },
    "token_estimate": { "type": "integer", "minimum": 1 },
    "contains_code": { "type": "boolean" },
    "contains_table": { "type": "boolean" },
    "contains_warning": { "type": "boolean" },
    "index_warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
