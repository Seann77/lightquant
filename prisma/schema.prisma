generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
}

enum SmsScene {
  login
}

enum CreditLedgerDirection {
  in
  out
}

enum CreditLedgerStatus {
  posted
  voided
}

enum CreditLedgerType {
  bonus
  recharge
  consume
  refund
}

enum PayChannel {
  wechat
  alipay
  mock
}

enum OrderStatus {
  PENDING
  PAID
  CLOSED
  FAILED
}

enum PaymentProvider {
  wechat
  alipay
  mock
}

enum PaymentTransactionStatus {
  NOTIFIED
  VERIFIED
  DUPLICATE
  FAILED
}

enum AiTaskType {
  strategy_generation
  code_conversion
  code_analysis
}

enum AiTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AiTaskScopeStatus {
  in_scope
  out_of_scope
}

enum AiConversationMode {
  strategy
  convert
  analysis
}

enum AiConversationStatus {
  active
  archived
}

enum AiMessageRole {
  user
  assistant
  system
}

enum AiMessageAttachmentRole {
  input
  reference
  generated
}

enum AiRunEventStatus {
  pending
  running
  completed
  failed
  skipped
}

enum AiRunEventVisibility {
  public
  debug
  admin_only
}

enum CreditReservationStatus {
  RESERVED
  CONFIRMED
  RELEASED
}

enum UploadedFileParseStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum UploadedFileScanStatus {
  PASSED
  BLOCKED
  WARNING
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  phone       String     @unique @db.VarChar(20)
  displayName String     @map("display_name") @db.VarChar(80)
  inviteCode  String     @unique @map("invite_code") @db.VarChar(32)
  referredBy  String?    @map("referred_by") @db.Uuid
  status      UserStatus @default(active)
  createdAt   DateTime   @map("created_at") @db.Timestamptz(3)
  lastLoginAt DateTime   @map("last_login_at") @db.Timestamptz(3)

  creditAccount      CreditAccount?
  creditLedger       CreditLedger[]
  creditReservations CreditReservation[]
  rechargeOrders     RechargeOrder[]
  aiTasks            AiTask[]
  aiConversations    AiConversation[]
  aiMessages         AiMessage[]
  aiMessageAttachments AiMessageAttachment[]
  aiRunEvents        AiRunEvent[]
  uploadedFiles      UploadedFile[]
  legalConsents      UserLegalConsent[]

  @@map("users")
}

model UserLegalConsent {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  agreementVersion String   @map("agreement_version") @db.VarChar(40)
  privacyVersion   String   @map("privacy_version") @db.VarChar(40)
  agreedAt         DateTime @map("agreed_at") @db.Timestamptz(3)
  requestIp        String?  @map("request_ip") @db.VarChar(80)
  userAgent        String?  @map("user_agent") @db.VarChar(512)
  source           String   @db.VarChar(40)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agreementVersion, privacyVersion])
  @@index([userId, agreedAt])
  @@map("user_legal_consents")
}

model SmsCode {
  id        String    @id @default(uuid()) @db.Uuid
  phone     String    @db.VarChar(20)
  scene     SmsScene
  codeHash  String?   @map("code_hash") @db.VarChar(255)
  mockCode  String?   @map("mock_code") @db.VarChar(32)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  requestIp String?   @map("request_ip") @db.VarChar(80)
  createdAt DateTime  @map("created_at") @db.Timestamptz(3)

  @@index([phone, scene, expiresAt])
  @@map("sms_codes")
}

model CreditAccount {
  userId      String   @id @map("user_id") @db.Uuid
  balance     Int
  totalEarned Int      @map("total_earned")
  totalSpent  Int      @map("total_spent")
  version     Int
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CreditLedger {
  id             String                @id @default(uuid()) @db.Uuid
  userId         String                @map("user_id") @db.Uuid
  requestId      String                @map("request_id") @db.VarChar(80)
  scene          String                @db.VarChar(80)
  type           CreditLedgerType
  direction      CreditLedgerDirection
  amount         Int
  balanceAfter   Int                   @map("balance_after")
  status         CreditLedgerStatus
  sourceType     String                @map("source_type") @db.VarChar(80)
  sourceId       String                @map("source_id") @db.VarChar(120)
  idempotencyKey String                @unique @map("idempotency_key") @db.VarChar(160)
  remark         String                @db.Text
  createdAt      DateTime              @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_ledger")
}

model CreditReservation {
  id             String                  @id @default(uuid()) @db.Uuid
  userId         String                  @map("user_id") @db.Uuid
  taskId         String                  @unique @map("task_id") @db.Uuid
  amount         Int
  status         CreditReservationStatus
  idempotencyKey String                  @unique @map("idempotency_key") @db.VarChar(160)
  expiresAt      DateTime                @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime                @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                @map("updated_at") @db.Timestamptz(3)

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task AiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("credit_reservations")
}

model RechargePlan {
  id          String   @id @db.VarChar(40)
  name        String   @db.VarChar(80)
  description String   @db.Text
  priceCents  Int      @map("price_cents")
  points      Int
  bonusPoints Int      @map("bonus_points")
  totalPoints Int      @map("total_points")
  enabled     Boolean
  sort        Int
  createdAt   DateTime @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(3)

  orders RechargeOrder[]

  @@map("recharge_plans")
}

model RechargeOrder {
  id              String      @id @default(uuid()) @db.Uuid
  orderNo         String      @unique @map("order_no") @db.VarChar(80)
  userId          String      @map("user_id") @db.Uuid
  planId          String      @map("plan_id") @db.VarChar(40)
  amountCents     Int         @map("amount_cents")
  points          Int
  bonusPoints     Int         @map("bonus_points")
  totalPoints     Int         @map("total_points")
  payChannel      PayChannel  @map("pay_channel")
  status          OrderStatus
  clientRequestId String      @map("client_request_id") @db.VarChar(120)
  paidAt          DateTime?   @map("paid_at") @db.Timestamptz(3)
  closedAt        DateTime?   @map("closed_at") @db.Timestamptz(3)
  createdAt       DateTime    @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime    @map("updated_at") @db.Timestamptz(3)

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         RechargePlan         @relation(fields: [planId], references: [id])
  transactions PaymentTransaction[]

  @@unique([userId, clientRequestId])
  @@index([userId, createdAt])
  @@index([planId])
  @@index([status, createdAt])
  @@map("orders")
}

model PaymentTransaction {
  id                String                   @id @default(uuid()) @db.Uuid
  orderId           String                   @map("order_id") @db.Uuid
  provider          PaymentProvider
  providerTradeNo   String                   @map("provider_trade_no") @db.VarChar(120)
  notifyId          String                   @map("notify_id") @db.VarChar(160)
  amountCents       Int                      @map("amount_cents")
  status            PaymentTransactionStatus
  rawPayload        Json                     @map("raw_payload")
  idempotencyKey    String                   @unique @map("idempotency_key") @db.VarChar(160)
  verifiedAt        DateTime?                @map("verified_at") @db.Timestamptz(3)
  failedReason      String?                  @map("failed_reason") @db.Text
  orderStatusBefore OrderStatus?             @map("order_status_before")
  orderStatusAfter  OrderStatus?             @map("order_status_after")
  createdAt         DateTime                 @map("created_at") @db.Timestamptz(3)

  order RechargeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, notifyId])
  @@index([orderId])
  @@map("payment_transactions")
}

model UploadedFile {
  id           String                  @id @default(uuid()) @db.Uuid
  userId       String                  @map("user_id") @db.Uuid
  originalName String                  @map("original_name") @db.VarChar(255)
  kind         String?                 @db.VarChar(40)
  ext          String                  @db.VarChar(16)
  mimeType     String                  @map("mime_type") @db.VarChar(120)
  sizeBytes    Int                     @map("size_bytes")
  sha256       String                  @db.VarChar(64)
  storageKey   String?                 @map("storage_key") @db.VarChar(512)
  thumbnailKey String?                 @map("thumbnail_key") @db.VarChar(512)
  contentText  String?                 @map("content_text") @db.Text
  contentJson  Json?                   @map("content_json")
  parseStatus  UploadedFileParseStatus @map("parse_status")
  scanStatus   UploadedFileScanStatus  @map("scan_status")
  riskFlags    Json                    @map("risk_flags")
  createdAt    DateTime                @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime?               @map("updated_at") @db.Timestamptz(3)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiTasks AiTask[]
  messageAttachments AiMessageAttachment[]

  @@index([userId, createdAt])
  @@index([userId, kind, createdAt])
  @@index([sha256])
  @@map("uploaded_files")
}

model AiTask {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  conversationId  String?           @map("conversation_id") @db.Uuid
  type            AiTaskType
  status          AiTaskStatus
  scopeStatus     AiTaskScopeStatus @default(in_scope) @map("scope_status")
  sourcePlatform  String?           @map("source_platform") @db.VarChar(80)
  targetPlatform  String?           @map("target_platform") @db.VarChar(80)
  prompt          String?           @db.Text
  inputCode       String?           @map("input_code") @db.Text
  inputFileId     String?           @map("input_file_id") @db.Uuid
  costPoints      Int               @map("cost_points")
  clientRequestId String            @map("client_request_id") @db.VarChar(120)
  requestId       String            @map("request_id") @db.VarChar(80)
  errorCode       String?           @map("error_code") @db.VarChar(80)
  errorMessage    String?           @map("error_message") @db.Text
  startedAt       DateTime?         @map("started_at") @db.Timestamptz(3)
  finishedAt      DateTime?         @map("finished_at") @db.Timestamptz(3)
  createdAt       DateTime          @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime          @map("updated_at") @db.Timestamptz(3)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation AiConversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  inputFile    UploadedFile?       @relation(fields: [inputFileId], references: [id], onDelete: SetNull)
  result       AiTaskResult?
  reservation  CreditReservation?
  messages     AiMessage[]
  runEvents    AiRunEvent[]

  @@unique([userId, clientRequestId])
  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([inputFileId])
  @@map("ai_tasks")
}

model AiTaskResult {
  taskId         String            @id @map("task_id") @db.Uuid
  resultType     AiTaskType        @map("result_type")
  scopeStatus    AiTaskScopeStatus @map("scope_status")
  generatedCode  String?           @map("generated_code") @db.Text
  explanation    String?           @db.Text
  migrationNotes String?           @map("migration_notes") @db.Text
  riskWarnings   Json              @map("risk_warnings")
  reportJson     Json?             @map("report_json")
  model          String            @db.VarChar(120)
  tokenUsage     Json              @map("token_usage")
  createdAt      DateTime          @map("created_at") @db.Timestamptz(3)

  task AiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("ai_task_results")
}

model AiConversation {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  mode           AiConversationMode
  title          String               @db.VarChar(120)
  targetPlatform String?              @map("target_platform") @db.VarChar(80)
  sourcePlatform String?              @map("source_platform") @db.VarChar(80)
  status         AiConversationStatus @default(active)
  uiState        Json?                @map("ui_state")
  lastMessageAt  DateTime             @map("last_message_at") @db.Timestamptz(3)
  createdAt      DateTime             @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @map("updated_at") @db.Timestamptz(3)

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks    AiTask[]
  messages AiMessage[]
  attachments AiMessageAttachment[]
  runEvents AiRunEvent[]

  @@index([userId, mode, lastMessageAt])
  @@index([status, lastMessageAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  role           AiMessageRole
  taskId         String?       @unique @map("task_id") @db.Uuid
  content        String        @db.Text
  contentJson    Json?         @map("content_json")
  createdAt      DateTime      @map("created_at") @db.Timestamptz(3)

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         AiTask?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  attachments  AiMessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_messages")
}

model AiMessageAttachment {
  id             String                  @id @default(uuid()) @db.Uuid
  messageId      String                  @map("message_id") @db.Uuid
  conversationId String                  @map("conversation_id") @db.Uuid
  userId         String                  @map("user_id") @db.Uuid
  fileId         String                  @map("file_id") @db.Uuid
  role           AiMessageAttachmentRole @default(input)
  displayOrder   Int                     @default(0) @map("display_order")
  caption        String?                 @db.VarChar(255)
  createdAt      DateTime                @map("created_at") @db.Timestamptz(3)

  message      AiMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  file         UploadedFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([messageId, fileId, role])
  @@index([messageId, displayOrder])
  @@index([conversationId, createdAt])
  @@index([fileId])
  @@index([userId, createdAt])
  @@map("ai_message_attachments")
}

model AiRunEvent {
  id              String               @id @default(uuid()) @db.Uuid
  taskId          String               @map("task_id") @db.Uuid
  conversationId  String?              @map("conversation_id") @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  seq             Int
  type            String               @db.VarChar(80)
  status          AiRunEventStatus     @default(running)
  title           String               @db.VarChar(160)
  summary         String?              @db.Text
  detailJson      Json?                @map("detail_json")
  progressPercent Int?                 @map("progress_percent")
  visibility      AiRunEventVisibility @default(public)
  createdAt       DateTime             @map("created_at") @db.Timestamptz(3)

  task         AiTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, seq])
  @@index([taskId, createdAt])
  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_run_events")
}
