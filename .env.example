LIGHTQUANT_DATA_MODE=mock
AUTH_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_SITE_URL=https://your-domain.com
BETA_VIP_ENABLED=true
BETA_VIP_REGISTRATION_DEADLINE=2026-06-28T15:59:59.999Z
BETA_VIP_DAILY_TASK_LIMIT=200
BETA_VIP_MINUTE_TASK_LIMIT=5
BETA_VIP_CONCURRENT_TASK_LIMIT=2
# Supabase pooler example usually needs sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require
LIGHTQUANT_PAYMENT_MODE=mock
PAYMENT_FEATURE_ENABLED=false
PAYMENT_MOCK_ENABLED=true
# mock, aliyun, or tencent. Production deploy defaults to tencent; set explicitly outside local mock use.
LIGHTQUANT_SMS_PROVIDER=
LIGHTQUANT_ALLOW_MOCK_SMS_IN_PRODUCTION=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_DYPNS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_DYPNS_COUNTRY_CODE=86
ALIYUN_DYPNS_SIGN_NAME=
ALIYUN_DYPNS_TEMPLATE_CODE=100001
ALIYUN_DYPNS_VALID_TIME=300
ALIYUN_DYPNS_INTERVAL=60
ALIYUN_DYPNS_CODE_LENGTH=6
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_TEMPLATE_PARAM_KEYS=code,minutes
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com
TENCENT_SMS_COUNTRY_CODE=86
TENCENT_SMS_VALID_TIME=300
TENCENT_SMS_CODE_LENGTH=6
PAYMENT_NOTIFY_BASE_URL=
PAYMENT_RETURN_BASE_URL=
PAYMENT_ORDER_EXPIRE_MINUTES=30
MAINTENANCE_SECRET=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_GATEWAY_URL=
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERTIFICATE=
WECHAT_PAY_GATEWAY_URL=
LIGHTQUANT_AI_PROVIDER=mock
LIGHTQUANT_ALLOW_MOCK_AI_IN_PRODUCTION=false
LIGHTQUANT_AI_API_KEY=
LIGHTQUANT_AI_BASE_URL=
LIGHTQUANT_AI_MODEL=
LIGHTQUANT_AI_SUPPORTS_VISION=
# Long MiMo code generation/conversion can stream for several minutes.
AI_TASK_TIMEOUT_MS=300000
AI_MAX_RETRIES=1
FILE_UPLOAD_MAX_BYTES=1048576
FILE_IMAGE_UPLOAD_MAX_BYTES=8388608
FILE_STORAGE_ROOT=.lightquant/uploads
FILE_ALLOWED_EXTENSIONS=.py,.txt,.log,.png,.jpg
ADMIN_ASSET_STORAGE_ROOT=.lightquant/admin-assets
WECHAT_GROUP_QR_MAX_BYTES=2097152
ADMIN_WRITE_ENABLED=false
ADMIN_MODEL_CONFIG_WRITE_ENABLED=false
CONFIG_ENCRYPTION_KEY=
ADMIN_PHONE_WHITELIST=

# DeepSeek preset:
# LIGHTQUANT_AI_PROVIDER=deepseek
# LIGHTQUANT_AI_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=
#
# Xiaomi MiMo Pro OpenAI-compatible preset:
# LIGHTQUANT_AI_PROVIDER=openai_compatible
# LIGHTQUANT_AI_BASE_URL=https://api.xiaomimimo.com/v1
# LIGHTQUANT_AI_MODEL=mimo-v2.5-pro
# LIGHTQUANT_AI_API_KEY=

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
